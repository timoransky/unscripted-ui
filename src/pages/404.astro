---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - unscripted/ui">
  <main class="flex flex-1 flex-col items-center justify-center gap-3 px-5 py-24 text-center">
    <p class="font-mono text-xs text-muted-foreground">404</p>
    <h1 class="font-display text-3xl font-bold tracking-tight">Nothing here.</h1>
    <p class="max-w-[46ch] text-muted-foreground">
      This page shipped 0 bytes of JavaScript... and also 0 bytes of content.
    </p>
    <a
      href="/"
      class="mt-2 inline-flex h-9 items-center justify-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
    >
      Back home
    </a>
  </main>
</BaseLayout>
