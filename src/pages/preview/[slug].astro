---
import { getCollection } from 'astro:content';
import PreviewLayout from '../../layouts/PreviewLayout.astro';

// Same raw-fragment glob the docs' ComponentPreview uses, so previews never
// drift from what the component actually ships.
const demos = import.meta.glob<string>('../../demos/**/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const cssFiles = import.meta.glob<string>('../../demos/**/*.css', {
  query: '?raw',
  import: 'default',
  eager: true,
});

export async function getStaticPaths() {
  // Dev-only: these previews exist while running `astro dev` but emit nothing
  // into `dist`, so they never ship to production.
  if (!import.meta.env.DEV) return [];
  const entries = await getCollection('components');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title },
  }));
}

const { slug } = Astro.params;
const { title } = Astro.props;

// Pick the folder's primary fragment: basic → variants → first available.
const prefix = `../../demos/${slug}/`;
const fragments = Object.entries(demos).filter(([path]) => path.startsWith(prefix));
const primary =
  fragments.find(([p]) => p.endsWith('/basic.html')) ??
  fragments.find(([p]) => p.endsWith('/variants.html')) ??
  fragments[0];

if (!primary) throw new Error(`No demo fragment found for slug: ${slug}`);
const html = primary[1].trim();

// Inject any colocated escape-hatch CSS (slider/fill, carousel/markers, …).
const css = Object.entries(cssFiles)
  .filter(([path]) => path.startsWith(prefix))
  .map(([, source]) => source.trim())
  .join('\n');
---

<PreviewLayout title={`${title} - preview`}>
  {css && <Fragment slot="head" set:html={`<style>${css}</style>`} />}
  <div class="flex w-full flex-wrap items-center justify-center gap-3" set:html={html} />
</PreviewLayout>
