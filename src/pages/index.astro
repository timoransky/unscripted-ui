---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SupportBadge from '../components/SupportBadge.astro';
import { FEATURES } from '../data/features';

const demos = import.meta.glob<string>('../demos/**/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const cssFiles = import.meta.glob<string>('../demos/**/*.css', {
  query: '?raw',
  import: 'default',
  eager: true,
});

// Which demo fragment represents each component on the landing page.
// Order matters: the first half fills the left column, the second half the
// right one, and on small screens the cards stack in exactly this order.
const SHOWCASE: Record<string, { demo: string; css?: string; align?: 'start' | 'center' }> = {
  drawer: { demo: 'drawer/basic' },
  tooltip: { demo: 'tooltip/toolbar' },
  gallery: { demo: 'gallery/basic' },
  textarea: { demo: 'textarea/basic' },
  'dropdown-menu': { demo: 'dropdown-menu/basic' },
  meter: { demo: 'meter/basic'},
  accordion: { demo: 'accordion/basic'},
  'nav-menu': { demo: 'nav-menu/basic' },
  header: { demo: 'header/basic' },
  select: { demo: 'select/basic' },
  marquee: { demo: 'marquee/basic', css: 'marquee/loop' },
};

const entries = await getCollection('components');
const components = Object.keys(SHOWCASE).map((id) => {
  const entry = entries.find((candidate) => candidate.id === id);
  if (!entry) throw new Error(`index: SHOWCASE id "${id}" has no matching component entry`);
  return entry;
});
const half = Math.ceil(components.length / 2);
const columns = [components.slice(0, half), components.slice(half)];

---

<BaseLayout>
  <div class="relative bg-linear-to-b from-transparent via-transparent to-primary-foreground/80">
  <main class="mx-auto w-full max-w-6xl flex-1 px-5 py-12">
    <header class="stagger mb-12">
      <h1 class="text-3xl font-bold tracking-tight">
        unscripted<span class="font-normal text-muted-foreground">/ui</span>
      </h1>
      <p class="mt-2.5 max-w-[52ch] text-pretty text-muted-foreground">
        shadcn-style components built from pure HTML and Tailwind without any JS framework or
        dependencies. Every interaction on this page (opening, closing, animating, positioning,
        dismissing) happens with no script at all. Copy the code, paste it, ship zero JavaScript. Works
        with your existing shadcn theme tokens.
      </p>
      <div class="mt-5 flex flex-col flex-wrap items-start gap-3">
        <a
          href="/docs/introduction"
          class="inline-flex h-9 items-center justify-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
        >
          Get started
        </a>
      </div>
      <p class="mt-4 text-xs text-muted-foreground">
        The badges below are live! They say whether <em>your</em> browser supports each
        feature, detected with <code class="font-mono">@supports</code>, no JS.
      </p>
    </header>

    <div class="relative">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {columns.map(column => (
        <div class="stagger flex flex-col gap-6 [--stagger-base:250ms] [--stagger-step:100ms]">
        {
          column.map((entry) => {
            const config = SHOWCASE[entry.id]!;
            const html = demos[`../demos/${config.demo}.html`];
            const requiredCss = config.css ? cssFiles[`../demos/${config.css}.css`] : undefined;
            const liveBadges = entry.data.features.filter((key) => FEATURES[key].supportsQuery).slice(0, 2);
            return (
              <section class="overflow-clip bg-background rounded-xl border border-border">
                <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-1.5 border-b border-border px-5 py-3.5">
                  <h2 class="text-[0.95rem] font-semibold tracking-tight">
                    <a href={`/components/${entry.id}`} class="underline-offset-4 hover:underline">
                      {entry.data.title}
                    </a>
                  </h2>
                  <div class="flex flex-wrap items-center gap-1.5">
                    {entry.data.plainCss && (
                      <span
                        class="rounded-full border border-border px-2.5 py-0.5 font-mono text-[0.68rem] text-muted-foreground"
                        title="Uses no leading-edge platform features"
                      >
                        plain CSS
                      </span>
                    )}
                    {liveBadges.map((key) => (
                      <SupportBadge feature={key} />
                    ))}
                    <a
                      href={`/components/${entry.id}`}
                      class="ml-1 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground"
                    >
                      code →
                    </a>
                  </div>
                </div>
                {requiredCss && <Fragment set:html={`<style>${requiredCss}</style>`} />}
                <div
                  class:list={[
                    'flex flex-wrap items-center gap-3 p-8',
                    (config.align ?? 'center') === 'center' && 'justify-center',
                  ]}
                  set:html={html}
                />
              </section>
            );
          })
        }
        </div>
        ))}
      </div>
    </div>
  </main>

  <div class="stagger pointer-events-none absolute flex items-end justify-center pb-15 inset-x-0 bottom-0 z-20 h-64 bg-linear-to-t from-background via-background/60 to-transparent lg:h-96 dark:via-background/80 [--stagger-base:750ms]">
    <a
      href="/components/accordion"
      class="pointer-events-auto flex h-9 items-center justify-center rounded-lg bg-background px-4 text-sm font-medium text-foreground border border-input transition-colors hover:bg-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
    >
      Explore all components
    </a>
  </div>

  </div>
</BaseLayout>

<style>
  @keyframes landing-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
  }

  .stagger > * {
    animation: landing-rise 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  /* The stagger itself is an enhancement: engines without sibling-index()
     drop the declaration and everything rises together at delay 0. The
     delays sit behind no-preference because the global reduced-motion rule
     shortens durations but leaves delays alone — a delayed `backwards` fill
     would keep content invisible. */
  @media (prefers-reduced-motion: no-preference) {
    .stagger > * {
      animation-delay: calc(
        var(--stagger-base, 0ms) + (sibling-index() - 1) * var(--stagger-step, 80ms)
      );
    }
  }
</style>
