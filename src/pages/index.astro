---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="mx-auto w-full max-w-6xl flex-1 px-5 py-10">
    <header class="mb-10 max-w-2xl">
      <h1 class="text-3xl font-bold tracking-tight">
        unscripted<span class="font-normal text-muted-foreground">/ui</span>
      </h1>
      <p class="mt-2 max-w-[52ch] text-muted-foreground">
        shadcn-style components rebuilt on raw web platform primitives. Every
        interaction — opening, closing, animating, positioning, dismissing — is
        HTML + CSS.
      </p>
    </header>
    <p class="text-sm text-muted-foreground">Showcase assembling in M6 — components land here as they're built.</p>
  </main>
</BaseLayout>
