---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SupportBadgeStyles from '../components/SupportBadgeStyles.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'unscripted/ui - zero-JS components on the web platform',
  description = 'shadcn-style components rebuilt on raw HTML and CSS primitives. Copy, paste, ship zero JavaScript.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <SupportBadgeStyles />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const dark = stored
        ? stored === 'dark'
        : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', dark);
    </script>
    <!-- Cloudflare Web Analytics: cookieless, privacy-friendly page + Core Web Vitals -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "0bb1ba7bc67748b780d389a24b0730d4"}`}
    ></script>
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <slot />
    <footer class="mt-auto border-t border-border">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-6 text-xs text-muted-foreground sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-1">
          <p id="footnote" class="max-w-lg">
            * The docs site ships a few tiny scripts: copy-to-clipboard, the theme
            toggle, linkable section headings, a shim so dialog demos work in
            browsers without invoker commands, and a cookieless, privacy-friendly
            analytics beacon. The components ship none.
          </p>
          <p>
            Built on the web platform. Components are yours to copy — no attribution, no install.
          </p>
        </div>
        <p class="flex shrink-0 items-center gap-1">
          built by <a href="https://janci.dev" class="font-medium text-muted-foreground transition-colors hover:text-foreground">janci.dev</a> with
          <img
            src="/claude-fu.gif"
            alt="Claude"
            width="24"
            height="24"
            class="inline-block size-6 [image-rendering:pixelated]"
          />
        </p>
      </div>
    </footer>
    <script src="../scripts/site.ts"></script>
  </body>
</html>
