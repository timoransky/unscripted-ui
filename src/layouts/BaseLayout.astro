---
import '../styles/global.css';
import Header from '../components/Header.astro';
import SupportBadgeStyles from '../components/SupportBadgeStyles.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'unscripted/ui — zero-JS components on the web platform',
  description = 'shadcn-style components rebuilt on raw HTML and CSS primitives. Copy, paste, ship zero JavaScript.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <SupportBadgeStyles />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const dark = stored
        ? stored === 'dark'
        : matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', dark);
    </script>
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header />
    <slot />
    <footer class="mt-auto border-t border-border">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-6 text-xs text-muted-foreground sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-1">
          <p id="footnote" class="max-w-lg">
            * The docs site ships a few tiny scripts: copy-to-clipboard, the theme
            toggle, and a shim so dialog demos work in browsers without invoker
            commands. The components ship none.
          </p>
          <p>
            Built on the web platform. Components are yours to copy — no attribution, no install.
          </p>
        </div>
        <p class="flex shrink-0 items-center gap-1">
          built with
          <img
            src="/claude-fu.gif"
            alt="Claude"
            width="24"
            height="24"
            class="inline-block size-6 [image-rendering:pixelated]"
          />
          and <a href="https://janci.dev" class="font-medium text-muted-foreground transition-colors hover:text-foreground">janci.dev</a>
        </p>
      </div>
    </footer>
    <script src="../scripts/site.ts"></script>
  </body>
</html>
