---
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-2 px-5 sm:gap-4">
    <a href="/" class="font-display text-base font-bold tracking-tight">
      unscripted<span class="font-normal text-muted-foreground">/ui</span>
    </a>
    <span class="hidden rounded-full border border-border px-2.5 py-0.5 font-mono text-[0.7rem] text-muted-foreground sm:inline-block">
      &lt;script&gt; bytes shipped: 0<a href="#footnote" class="no-underline" aria-label="See footnote">*</a>
    </span>
    <nav class="ml-auto flex items-center gap-1 text-sm">
      {/* Desktop: inline links. Mobile: the same destinations live in the drawer. */}
      <a href="/docs/introduction" class="hidden rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground sm:px-3 lg:inline-block">Docs</a>
      <a href="/components/accordion" class="hidden rounded-md px-2 py-1.5 text-muted-foreground transition-colors hover:bg-accent hover:text-foreground sm:px-3 lg:inline-block">Components</a>
      <a
        href="https://github.com/timoransky/unscripted-ui"
        class="hidden size-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground lg:inline-flex"
        aria-label="GitHub repository"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.75 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.77 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.25 5.67.41.35.77 1.04.77 2.1v3.11c0 .3.21.66.8.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"></path>
        </svg>
      </a>
      <ThemeToggle />
      <MobileNav />
    </nav>
  </div>
</header>
