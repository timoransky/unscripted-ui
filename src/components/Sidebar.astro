---
import { getCollection } from 'astro:content';

const components = await getCollection('components');
const current = Astro.url.pathname.replace(/\/$/, '');

// Sidebar taxonomy: every component sits in exactly one category so the 30+
// item list stays scannable. The build throws below if a component is unmapped
// (or an id here is unknown), so a newly added component can't silently drop
// out of the nav. Within a category, links keep the authored `order`.
const CATEGORIES: { label: string; ids: string[] }[] = [
  { label: 'Forms', ids: ['button', 'input', 'textarea', 'label', 'checkbox', 'radio-group', 'switch', 'select', 'slider'] },
  { label: 'Overlays', ids: ['dialog', 'alert-dialog', 'drawer', 'popover', 'dropdown-menu', 'hover-card', 'tooltip'] },
  { label: 'Navigation', ids: ['nav-menu', 'tabs', 'accordion', 'header'] },
  { label: 'Feedback', ids: ['alert', 'badge', 'progress', 'meter', 'skeleton'] },
  { label: 'Display', ids: ['card', 'avatar', 'gallery', 'marquee', 'carousel'] },
  { label: 'Motion & scroll', ids: ['scroll-area', 'scroll-indicator', 'stagger'] },
];

const byId = new Map(components.map((c) => [c.id, c]));
const unknown = CATEGORIES.flatMap((cat) => cat.ids).filter((id) => !byId.has(id));
if (unknown.length) throw new Error(`Sidebar: unknown component ids in taxonomy: ${unknown.join(', ')}`);
const mapped = new Set(CATEGORIES.flatMap((cat) => cat.ids));
const missing = components.filter((c) => !mapped.has(c.id)).map((c) => c.id);
if (missing.length) throw new Error(`Sidebar: components missing a category: ${missing.join(', ')}`);

const groups = [
  {
    label: 'Docs',
    links: [
      { href: '/docs/introduction', title: 'Introduction' },
      { href: '/docs/installation', title: 'Installation' },
    ],
  },
  ...CATEGORIES.map((cat) => ({
    label: cat.label,
    links: cat.ids
      .map((id) => byId.get(id)!)
      .sort((a, b) => a.data.order - b.data.order)
      .map((c) => ({ href: `/components/${c.id}`, title: c.data.title })),
  })),
];
---

<aside class="lg:py-8">
  {/* mobile: zero-JS disclosure, same <details> primitive the library documents */}
  <details class="border-b border-border py-3 lg:hidden">
    <summary class="cursor-pointer list-none text-sm font-medium [&::-webkit-details-marker]:hidden">
      Browse components
    </summary>
    <nav class="pt-3">
      {groups.map((group) => (
        <div class="mb-4">
          <p class="mb-1.5 text-xs font-semibold tracking-wide text-muted-foreground uppercase">{group.label}</p>
          <ul class="space-y-0.5">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={current === link.href ? 'page' : undefined}
                  class="block rounded-md px-2 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground aria-[current=page]:bg-accent aria-[current=page]:font-medium aria-[current=page]:text-foreground"
                >
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </details>

  <nav class="sticky top-20 hidden max-h-[calc(100dvh-6rem)] overflow-y-auto pr-2 lg:block [container-type:scroll-state]">
    {/* Same scroll-area trick the library documents: fade edges appear only when there's more to scroll. */}
    <div class="pointer-events-none sticky top-0 z-10 -mb-6 h-6 bg-linear-to-b from-background to-transparent opacity-0 transition-opacity [@container_scroll-state(scrollable:top)]:opacity-100"></div>
    {groups.map((group) => (
      <div class="mb-6">
        <p class="mb-1.5 text-xs font-semibold tracking-wide text-muted-foreground uppercase">{group.label}</p>
        <ul class="space-y-0.5">
          {group.links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={current === link.href ? 'page' : undefined}
                class="block rounded-md px-2 py-1 text-sm text-muted-foreground transition-colors hover:text-foreground aria-[current=page]:bg-accent aria-[current=page]:font-medium aria-[current=page]:text-foreground"
              >
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
    <div class="pointer-events-none sticky bottom-0 z-10 -mt-6 h-6 bg-linear-to-t from-background to-transparent opacity-0 transition-opacity [@container_scroll-state(scrollable:bottom)]:opacity-100"></div>
  </nav>
</aside>
