---
/**
 * The official Baseline status mark (widely / newly / limited), served from the
 * unmodified assets vendored in /public/baseline. The Baseline logos are Google
 * trademarks under CC-BY-ND 4.0 — the colors encode the support level, so they
 * must not be recolored or altered (see public/baseline/README.md).
 *
 * Light and dark variants are swapped with the site's class-based dark mode
 * (@custom-variant dark in global.css), the same zero-JS technique ThemeToggle
 * uses. Static <img>, no client JS, no external request.
 */
type Status = 'high' | 'low' | 'limited';

interface Props {
  status: Status;
  class?: string;
}

const { status, class: className } = Astro.props;

const NAME: Record<Status, string> = { high: 'widely', low: 'newly', limited: 'limited' };
const name = NAME[status];
const base = `/baseline/baseline-${name}-icon`;
---

<img src={`${base}.svg`} alt="" class:list={['dark:hidden', className]} />
<img src={`${base}-dark.svg`} alt="" class:list={['hidden dark:block', className]} />
