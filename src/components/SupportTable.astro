---
import { FEATURES, type FeatureInfo, type FeatureKey } from '../data/features';
import { resolveSupport, type ResolvedSupport } from '../data/support';

interface Props {
  features: FeatureKey[];
}

// The widened Row type matters: FEATURES entries are literal types, and only
// some carry `proxy` — accessing it on their union is a type error.
type Row = FeatureInfo & ResolvedSupport & { key: FeatureKey };

const { features } = Astro.props;
const rows: Row[] = features.map((key) => ({ key, ...FEATURES[key], ...resolveSupport(key) }));
const proxied = rows.filter((r) => r.proxy);
const undetectable = rows.filter((r) => !r.supportsQuery);

const version = (v: string) => (v === 'no' ? '✕' : v);

const BASELINE_CHIP = {
  high: {
    text: () => 'Baseline · widely available',
    class: 'border-emerald-600/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400',
  },
  low: {
    text: (year?: string) => `Baseline ${year ?? ''} · newly available`.replace('  ', ' '),
    class: 'border-sky-600/30 bg-sky-500/10 text-sky-700 dark:text-sky-400',
  },
  limited: {
    text: () => 'Limited availability',
    class: 'border-amber-600/30 bg-amber-500/10 text-amber-700 dark:text-amber-400',
  },
} as const;

const chipFor = (row: (typeof rows)[number]) =>
  row.baseline === null ? null : BASELINE_CHIP[row.baseline === false ? 'limited' : row.baseline];
---

{
  rows.length > 0 && (
    <section class="mt-12">
      <h2 id="browser-support" class="mb-1 scroll-mt-20 text-lg font-semibold tracking-tight">
        Browser support
        <a
          class="heading-anchor"
          data-heading-anchor
          href="#browser-support"
          aria-label="Copy link to this section"
        />
      </h2>
      <p class="mb-4 max-w-[70ch] text-sm text-muted-foreground">
        Minimum stable version per engine, resolved at build time from MDN's
        browser-compat-data; Baseline status from the official web-features dataset.
        Everything degrades gracefully — the “when missing” column is the actual
        behavior, not a broken page.
      </p>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-border bg-muted/50 text-left">
              <th scope="col" class="px-3 py-2 font-medium">Feature</th>
              <th scope="col" class="px-3 py-2 text-center font-medium">Chrome</th>
              <th scope="col" class="px-3 py-2 text-center font-medium">Edge</th>
              <th scope="col" class="px-3 py-2 text-center font-medium">Firefox</th>
              <th scope="col" class="px-3 py-2 text-center font-medium">Safari</th>
              <th scope="col" class="px-3 py-2 font-medium">When missing</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => {
              const chip = chipFor(row);
              return (
                <tr class="border-b border-border last:border-0">
                  <th scope="row" class="px-3 py-2.5 text-left font-normal">
                    <a
                      href={row.mdn}
                      class="underline decoration-border underline-offset-4 hover:decoration-foreground"
                    >
                      {row.label}
                    </a>
                    {row.proxy && <sup aria-hidden="true">†</sup>}
                    {!row.supportsQuery && <sup aria-hidden="true">‡</sup>}
                    {chip && (
                      <span
                        class:list={[
                          'mt-1.5 block w-fit rounded-full border px-2 py-px font-mono text-[0.62rem] whitespace-nowrap',
                          chip.class,
                        ]}
                      >
                        {chip.text(row.baselineYear)}
                      </span>
                    )}
                  </th>
                  {(['chrome', 'edge', 'firefox', 'safari'] as const).map((browser) => (
                    <td
                      class:list={[
                        'px-3 py-2.5 text-center font-mono text-xs',
                        row.versions[browser] === 'no' && 'text-muted-foreground',
                      ]}
                    >
                      {version(row.versions[browser])}
                    </td>
                  ))}
                  <td class="min-w-52 px-3 py-2.5 text-muted-foreground">{row.fallback}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      {(proxied.length > 0 || undetectable.length > 0) && (
        <div class="mt-3 space-y-1 text-xs text-muted-foreground">
          {proxied.map((row) => (
            <p>† {row.proxy}</p>
          ))}
          {undetectable.length > 0 && (
            <p>
              ‡ HTML feature — <code class="font-mono">@supports</code> can only test CSS, and we ship
              no JS to detect it, so it gets no live badge.
            </p>
          )}
        </div>
      )}
    </section>
  )
}
