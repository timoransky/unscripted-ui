---
import { Code } from 'astro:components';

interface Props {
  /** "accordion/basic" -> src/demos/accordion/basic.html */
  demo: string;
  /** "select/required" -> src/demos/select/required.css — the rare escape hatch */
  css?: string;
  align?: 'center' | 'start';
}

// One import, two uses: the same raw fragment renders as the live preview
// and is highlighted as the copyable code. It cannot drift.
const demos = import.meta.glob<string>('../demos/**/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const cssFiles = import.meta.glob<string>('../demos/**/*.css', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const { demo, css, align = 'center' } = Astro.props;

const code = demos[`../demos/${demo}.html`];
if (code === undefined) throw new Error(`ComponentPreview: demo not found: src/demos/${demo}.html`);
const requiredCss = css ? cssFiles[`../demos/${css}.css`] : undefined;
if (css && requiredCss === undefined)
  throw new Error(`ComponentPreview: css not found: src/demos/${css}.css`);

const uid = demo.replace(/[^a-zA-Z0-9]/g, '-');
const html = code.trim();
---

{/* The Preview/Code switcher is the library's own zero-JS radio-tabs technique. */}
<figure class="not-prose my-6 grid grid-cols-[auto_auto_1fr] overflow-clip rounded-xl border border-border">
  <input type="radio" name={`view-${uid}`} id={`view-${uid}-preview`} class="peer/preview sr-only" checked />
  <input type="radio" name={`view-${uid}`} id={`view-${uid}-code`} class="peer/code sr-only" />

  <label
    for={`view-${uid}-preview`}
    class="cursor-pointer border-b border-border px-4 py-2.5 font-mono text-xs text-muted-foreground underline-offset-8 transition-colors hover:text-foreground peer-checked/preview:text-foreground peer-checked/preview:underline peer-focus-visible/preview:outline-2 peer-focus-visible/preview:-outline-offset-2 peer-focus-visible/preview:outline-ring"
  >
    Preview
  </label>
  <label
    for={`view-${uid}-code`}
    class="cursor-pointer border-b border-border px-4 py-2.5 font-mono text-xs text-muted-foreground underline-offset-8 transition-colors hover:text-foreground peer-checked/code:text-foreground peer-checked/code:underline peer-focus-visible/code:outline-2 peer-focus-visible/code:-outline-offset-2 peer-focus-visible/code:outline-ring"
  >
    Code
  </label>
  <div class="flex items-center justify-end gap-1.5 border-b border-border px-4 py-2.5">
    <slot name="badges" />
  </div>

  {requiredCss && <Fragment set:html={`<style>${requiredCss}</style>`} />}

  <div
    class:list={[
      'col-span-3 hidden min-h-48 flex-wrap items-center gap-3 p-8',
      'peer-checked/preview:flex',
      align === 'center' && 'justify-center',
    ]}
    set:html={html}
  />

  <div
    class="relative col-span-3 hidden bg-[#24292e] peer-checked/code:block [&_pre]:max-h-[26rem] [&_pre]:overflow-auto [&_pre]:p-5 [&_pre]:text-[0.8rem]/[1.7] [&_pre]:outline-none"
    data-code-pane
  >
    <button
      type="button"
      data-copy
      aria-label="Copy code"
      class="absolute top-3 right-3 z-10 inline-flex size-8 cursor-pointer items-center justify-center rounded-md text-zinc-400 transition-colors hover:bg-white/10 hover:text-zinc-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-400"
    >
      <svg class="size-4 [[data-copied]_&]:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="14" height="14" x="8" y="8" rx="2"></rect>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
      </svg>
      <svg class="hidden size-4 text-emerald-400 [[data-copied]_&]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
    </button>
    <Code code={html} lang="html" theme="github-dark" />
    {
      requiredCss && (
        <>
          <p class="border-t border-zinc-700 px-5 pt-3 pb-0 font-mono text-[0.68rem] text-zinc-400">
            + required CSS — this part genuinely can't be expressed as utilities (the page explains why)
          </p>
          <Code code={requiredCss.trim()} lang="css" theme="github-dark" />
        </>
      )
    }
  </div>
</figure>
